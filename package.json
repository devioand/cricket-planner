{
  "name": "cricket-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate:dev": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.development.local scripts/migrate.mjs",
    "migrate:prod": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.production.local scripts/migrate.mjs",
    "migrate:dev:status": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.development.local scripts/migrate.mjs --status",
    "migrate:prod:status": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.production.local scripts/migrate.mjs --status",
    "db:branches": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.production.local scripts/neon-branch.mjs list",
    "db:dev:create": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.production.local scripts/neon-branch.mjs create-dev",
    "db:dev:reset": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.production.local scripts/neon-branch.mjs reset-dev"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.25.0",
    "@emotion/react": "^11.14.0",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "canvas-confetti": "^1.9.3",
    "html-to-image": "^1.11.13",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pg": "^8.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "29.5.12",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "^5"
  }
}
