# ── Environment files ─────────────────────────────────────────────────────────
# Next.js loads these by NODE_ENV automatically (no extra package):
#   .env.local               shared secrets — loaded in EVERY environment
#   .env.development.local    `next dev`                → Neon DEV branch
#   .env.production.local     `next build` / `next start` → Neon PRODUCTION branch
# All *.local files are gitignored. Copy the relevant sections below into them.

# ── .env.local (shared) ───────────────────────────────────────────────────────
# 32-byte secret used to sign/encrypt sessions. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000

# ── .env.development.local  AND  .env.production.local ────────────────────────
# The Neon (pooled) Postgres connection string for that environment's branch.
# Drop "&channel_binding=require" — the node-postgres driver doesn't use it.
DATABASE_URL=
