# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# ── Supabase Postgres ────────────────────────────────────────────────────────
# Session pooler connection string (port 5432). Used by Better Auth + the
# app's data layer. Get it from: Supabase Dashboard → Connect → Session pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# (Optional) Supabase project reference — kept for future client-side features.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── Better Auth ──────────────────────────────────────────────────────────────
# 32-byte secret used to sign/encrypt sessions.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000
